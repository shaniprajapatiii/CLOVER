# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/clover

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRE=30d

# Weather API (OpenWeatherMap - free tier)
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Air Quality API (OpenWeatherMap AQI)
AQI_API_URL=https://api.openweathermap.org/data/2.5/air_pollution

# Payment Gateway (Razorpay - sandbox)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# Optional second frontend domain (e.g., partner app on Vercel)
FRONTEND_URL_PARTNER=https://your-partner-app.vercel.app
# Allow *.vercel.app origins (useful for preview deployments)
ALLOW_VERCEL_APP_ORIGINS=true
# Optional emergency/demo OTP bypass code (leave empty in strict production)
OTP_BYPASS_CODE=

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# Fraud Detection Threshold
FRAUD_SCORE_THRESHOLD=0.75

# Cron Jobs
WEATHER_CHECK_INTERVAL=*/30 * * * *
CLAIM_AUTO_PROCESS_INTERVAL=0 * * * *

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/
